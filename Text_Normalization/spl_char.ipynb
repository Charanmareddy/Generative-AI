   ],
   "source": [
    "with open('data.txt','r+') as file:\n",
    "    data =  file.read()\n",
    "    for char in data:\n",
    "        if not char.isalnum() and not ord(char) == 32:\n",
    "            data = data.replace(char,'')\n",
    "            # print(data)\n",
    "    file.write(data)\n",
    "print(data)    "
